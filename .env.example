# Qdrant — vector database
# Point to your standalone Qdrant instance, or use: make run-with-qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-api-key-here
QDRANT_COLLECTION_PREFIX=biblion

# Embedding server (Ollama-compatible)
# Point to your standalone Ollama instance, or use: make run-with-ollama
EMBEDDING_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text:v1.5

# Tuning (optional — these are the defaults)
# DEDUP_THRESHOLD=0.95
# SEARCH_MIN_SCORE=0.45
# MAX_CANDIDATES=50
# SIMILARITY_WEIGHT=0.7
# USAGE_WEIGHT=0.2
# QUALITY_WEIGHT=0.1
# DEFAULT_QUALITY=0.5

# Server
# HOST=0.0.0.0
# PORT=18765

# Redis (primary storage + indexer backend)
# Use make run-with-redis to start a bundled Redis, or point to your own instance
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=indexer
INDEXER_MAX_FILE_SIZE=524288
INDEXER_CHUNK_SIZE=50
INDEXER_CHUNK_OVERLAP=10
INDEXER_TOP_K=10
INDEXER_MIN_SCORE=0.35
